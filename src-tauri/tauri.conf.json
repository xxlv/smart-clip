{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Clip",
  "version": "0.1.0",
  "identifier": "com.smart-clip.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Smart Clip",
        "width": 840,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "shortDescription": "Minimal clipboard with history",
    "longDescription": "Cross-platform clipboard with code highlight, Markdown preview, AME-backed history.",
    "category": "Utility",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {}
  },
  "plugins": {}
}
